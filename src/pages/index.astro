---
import Base from '../layouts/Base.astro';
import Home from '../components/Home.jsx';
import JournalNav from '../components/JournalNav.jsx';
import AdminFab from '../components/AdminFab.astro';

// Home fetches the full entry list at runtime (spotlight + paginated grid) so the static HTML stays flat.
---

<Base>
  <JournalNav slot="brand" current="home" client:load />
  <Home client:only="react" />
  <AdminFab />
</Base>
