---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import EntryEditor from '../../components/EntryEditor.jsx';
import { createdOf } from '../../lib/created.js';
import { parseTags } from '../../lib/tags.js';
import { EDITING_ENABLED } from '../../lib/capabilities.js';

// The entire editing surface, on one route: `/admin/new` creates an entry,
// `/admin/posts/<slug>` edits one. Both are gated in a single place — with editing
// off (the default outside dev; see EDITING_ENABLED / PUBLIC_ENABLE_EDITING),
// getStaticPaths returns nothing, so no /admin page is built. src/lib/adminBuild.js
// then keeps the editor island out of the bundle and bounces the prod /admin/* URL
// to the read view. Keeping the whole surface behind one prefix also means a single
// path (/admin/*) to auth-wall at the edge (e.g. Cloudflare Access).
export async function getStaticPaths() {
  if (!EDITING_ENABLED) return [];
  const posts = await getCollection('posts');
  return [
    { params: { path: 'new' }, props: { post: null } },
    ...posts.map((post) => ({ params: { path: `posts/${post.id}` }, props: { post } })),
  ];
}

// `post` is null for /admin/new, set for an edit. An edit seeds the editor from
// the same fields the read view derives (creation day from the filename, any
// `updated` stamp, tags); a new entry starts blank and dates itself on save.
const { post } = Astro.props;
const created = post ? createdOf(post) : null;
const tags = post ? parseTags(post.data.tags) : [];
---

<Base title={post ? `Editing: ${post.data.title}` : 'New entry'}>
  <EntryEditor
    markdown={post ? post.body : ''}
    title={post ? post.data.title : ''}
    date={created ? created.toISOString() : null}
    updated={post && post.data.updated ? post.data.updated.toISOString() : null}
    path={post ? `src/content/posts/${post.id}.md` : null}
    tags={tags.join(', ')}
    isNew={!post}
    client:only="react"
  />
</Base>
