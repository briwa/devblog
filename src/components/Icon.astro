---
import { ICONS } from '../icons.js';

const { name, size = 18, ...rest } = Astro.props;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  set:html={ICONS[name]}
  {...rest}
/>
