---
import '../styles/global.css';
import { SITE_NAME } from '../config.js';

const { title, noIndex } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title || SITE_NAME}</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'><text y='14' font-size='14'>📓</text></svg>" />
    <script is:inline>
      // Apply the saved theme before paint; no saved value = follow the device.
      const saved = localStorage.getItem('theme');
      if (saved) document.documentElement.setAttribute('data-theme', saved);
      // Dev-only code color scheme (falls back to the CSS default when unset).
      const savedCode = localStorage.getItem('codeTheme');
      if (savedCode) document.documentElement.setAttribute('data-code-theme', savedCode);
    </script>
    <slot name="head" />
  </head>
  <body {...(noIndex ? { 'data-pagefind-ignore': 'all' } : {})}>
    <slot />
  </body>
</html>
